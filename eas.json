{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "environment": "production", 
      "android": {
        "buildType": "app-bundle"
      }
    },
  "preview": {
    "distribution": "internal",
    "android": {
      "buildType": "apk"
    }
  },
    "development": {
      "environment": "development",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    }
  }
}
