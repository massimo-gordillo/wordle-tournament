{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "build:web": "expo export --platform web",
    "lint": "expo lint && npm run check:draft-route-effect",
    "check:draft-route-effect": "node scripts/assert-draft-tournament-route-effect.mjs",
    "typecheck": "tsc --noEmit",
    "supabase:play-review-seed": "node scripts/generate-play-review-seed.mjs",
    "copy:export:csv": "node scripts/export-copy-csv.mjs",
    "copy:import:csv": "node scripts/import-copy-csv.mjs",
    "supabase:status": "npx supabase status",
    "supabase:db:push": "npx supabase db push && npm run supabase:play-review-seed",
    "supabase:db:reset": "npx supabase db reset && npm run supabase:play-review-seed && npm run supabase:local-test-users-seed",
    "supabase:local-test-users-seed": "node scripts/seed-local-test-users.mjs",
    "test:db": "npx supabase test db",
    "test:cron-edge": "deno test supabase/functions/edge-run-daily-cron/cron_handler_test.ts",
    "supabase:functions:deploy": "npx supabase functions deploy update-leaderboard && npx supabase functions deploy delete-account",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.58.0",
    "expo": "^54.0.10",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.7",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.8",
    "expo-secure-store": "^55.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "supabase": "^2.76.15",
    "typescript": "~5.9.2"
  }
}
